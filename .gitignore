# Playwright MCP tool output — agents using the playwright MCP server land
# screenshots + snapshots here at the shell cwd. Never commit; evidence
# that matters goes under data/peer_reviews/<date>-evidence/ explicitly.
.playwright-mcp/
/*.png
/*.jpg
/*.jpeg

# Aider CLI session artifacts (operator's interactive tool)
.aider*
.superpowers/

# Capacitor — generated fresh in Codemagic CI, never committed
/ios
/www

# Per-spawn MCP config the dispatch listener writes into worker worktrees; if
