# Live artifact store (worker-generated files, written at runtime by
# artifactStore.ts as <repoRoot>/data/sully/artifacts). Operator-only runtime
# data — never commit; the gate already exempts data/.
data/sully/
# Personal data drops — chat exports, voice samples. Treat data/ as
# operator-only; only schema (in code) is committed, never the files.
data/*.zip
data/*.tar.gz
data/ch_data/

# QLoRA fine-tune scratch — venv + checkpoints live alongside the scripts
# but the artifacts themselves are heavyweight and never committed.
scripts/finetune/.venv/
scripts/finetune/__pycache__/
# Unsloth's per-run Triton kernel cache; lands in the cwd of train_qlora.py
# (= repo root by default). 3-10+ MB of compiled Python helpers per run.
unsloth_compiled_cache/

# Playwright e2e artifacts — traces, screenshots-on-failure, video, reports.
# Tests + config are committed; the run output is per-machine.
test-results/
playwright-report/
blob-report/
*.log
# Hermetic e2e harness per-run state (fresh DB + uploads per suite run, LOS-182)
.e2e-data/

# Operator-side working artifacts that should not ship in git.
data/peer_reviews/
docs/Screenshots /
docs/research/
docs/superpowers/plans/
