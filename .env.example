# LogueOS-Companion environment — KEY NAMES ONLY (no secrets).
# Regenerated from the live .env on 2026-06-02 so a fresh clone has the full surface.
# Fill in real values locally; never commit the populated .env.

ANTHROPIC_API_KEY=
# Daily token cap for Anthropic (default 1,000,000). When exceeded, the
# sdk-stream route falls back to Ollama Cloud models automatically.
ANTHROPIC_DAILY_TOKEN_CAP=
