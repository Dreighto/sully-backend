{
	"name": "sully-backend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"check:mobile-pwa": "node scripts/mobile-pwa-check.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"test": "vitest run",
		"routing:score": "ROUTING_SCORE_REPORT=1 vitest run tests/routing-scorecard.test.ts",
		"test:e2e": "npm run test:e2e:chromium && npm run test:e2e:webkit",
		"test:e2e:chromium": "playwright test --project=chromium-mutating",
		"test:e2e:webkit": "playwright test --project=iphone-webkit-mutating",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "8.3.4",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22",
		"@types/web-push": "^3.6.4",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-eslint-parser": "^1.6.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"sharp": "^0.32.6",
		"@ai-sdk/anthropic": "^3.0.79",
		"@ai-sdk/google": "^3.0.79",
		"@ai-sdk/openai-compatible": "^2.0.48",
		"@ai-sdk/svelte": "^4.0.191",
		"@capacitor/app": "8.1.0",
		"@capacitor/core": "8.3.4",
		"@capacitor/haptics": "8.0.2",
		"@capacitor/ios": "8.3.4",
		"@capacitor/keyboard": "8.0.3",
		"@capacitor/preferences": "8.0.1",
		"@capacitor/push-notifications": "^8.1.1",
		"@capacitor/share": "8.0.1",
		"@capacitor/splash-screen": "8.0.1",
		"@capacitor/status-bar": "8.0.2",
		"@fontsource-variable/bricolage-grotesque": "^5.2.10",
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"ai": "^6.0.191",
		"better-sqlite3": "^12.10.0",
		"bits-ui": "^2.18.1",
		"dompurify": "^3.4.5",
		"heic-convert": "^2.1.0",
		"highlight.js": "^11.11.1",
		"lottie-web": "^5.13.0",
		"lucide-svelte": "^1.0.1",
		"marked": "^18.0.4",
		"svelte-gestures": "^5.2.2",
		"web-push": "^3.6.7",
		"ws": "^8.20.1"
	}
}
